NODE_ENV=development
PORT=3001

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=react-agent

GUARDRAILS_MODEL=anthropic/claude-haiku-4-5-20251001
AGENT_MODEL=anthropic/claude-sonnet-4-6
MEMORY_MODEL=anthropic/claude-haiku-4-5-20251001

# Teto do loop ReAct — guarda alucinação por contexto longo
REACT_MAX_STEPS=6

# Memória (LONGA + CONTEXTUAL) — política fica no memory.md
MEMORY_DATABASE_URL=postgresql://harness:harness@localhost:5432/harness_memory
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# Harness / Langfuse (usados por evals/run.ts) — opcional p/ rodar o agente
JUDGE_MODEL=anthropic/claude-haiku-4-5-20251001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030
