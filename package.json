{
  "name": "harness-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "presets/*/apps/*",
    "examples/*/apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "eval": "turbo eval",
    "benchmark": "tsx scripts/benchmark.ts",
    "typecheck:scripts": "tsc --noEmit --project tsconfig.scripts.json"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "@langchain/langgraph": "1.1.3",
    "langchain": "1.2.25"
  }
}
