NODE_ENV=development
PORT=3001

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=reflection-agent

GUARDRAILS_MODEL=anthropic/claude-haiku-4-5-20251001
GENERATOR_MODEL=anthropic/claude-sonnet-4-6
# self-reflection: igual ao generator. cross-reflection: modelo maior (ex: opus)
CRITIC_MODEL=anthropic/claude-sonnet-4-6

# Teto de iterações do critic loop
REFLECTION_MAX_ITER=3

# Harness / Langfuse
JUDGE_MODEL=anthropic/claude-haiku-4-5-20251001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030
